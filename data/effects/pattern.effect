// Constellations - Tiled SDF pattern effect
// (c) 2026 Eion Dailey - GPLv2+

uniform float4x4 ViewProj;

uniform float2 canvas_size;
uniform float2 anchor;
uniform float cell_size;
uniform float shape_size;
uniform float shape_rotation;
uniform float4 shape_color;
uniform int shape_kind;
uniform int polygon_sides;
uniform float stroke_thickness;
uniform float outline_only;

uniform float2 lattice_dir;    // canvas rotation axes (cos, sin)
uniform float2 motion_offset;  // accumulated motion in lattice coords (along, perp) px
uniform float alt_lines;
uniform float drift_speed_amt;
uniform float drift_speed_seed; // shared across items unless per-item drift
uniform float drift_loc_amt;
uniform float item_seed;
uniform float elapsed_time;  // seconds since the source was created

uniform float twinkle_amount; // fraction of cells that twinkle (0 disables)
uniform float twinkle_speed;  // twinkle cycles per second

uniform float layout_mode;   // 0 layered, 1 step-repeat, 2 grid
uniform float grid_random;   // grid mode: 1 = random cell assignment, 0 = ordered
uniform float step_index;    // this item's slot in step-repeat rotation
uniform float step_count;    // total enabled items participating in step-repeat

uniform float vignette_enabled;
uniform float2 vignette_center;
uniform float vignette_size_px;
uniform float vignette_direction;
uniform int vignette_shape;
uniform int vignette_polygon_sides;
uniform float vignette_softness;
uniform float vignette_inverted;

uniform texture2d cell_texture;

sampler_state TileSampler {
	Filter   = Linear;
	AddressU = Clamp;
	AddressV = Clamp;
};

struct VertData {
	float4 pos : POSITION;
	float2 uv  : TEXCOORD0;
};

VertData VSDefault(VertData v_in)
{
	VertData v_out;
	v_out.pos = mul(float4(v_in.pos.xyz, 1.0), ViewProj);
	v_out.uv  = v_in.uv;
	return v_out;
}

float sd_circle(float2 p, float r)
{
	return length(p) - r;
}

float sd_box(float2 p, float2 b)
{
	float2 q = abs(p) - b;
	return length(max(q, 0.0)) + min(max(q.x, q.y), 0.0);
}

float sd_cross(float2 p, float arm_len, float arm_thick)
{
	float h = sd_box(p, float2(arm_len, arm_thick));
	float v = sd_box(p, float2(arm_thick, arm_len));
	return min(h, v);
}

float sd_polygon(float2 p, float r, int n)
{
	int sides = n;
	if (sides < 3) sides = 3;
	float fn = float(sides);
	float ang = atan2(p.x, p.y);
	float sector = 6.2831853 / fn;
	float idx = floor(ang / sector + 0.5);
	float a = idx * sector;
	float ca = cos(a);
	float sa = sin(a);
	float2 pr = float2(ca * p.x - sa * p.y, sa * p.x + ca * p.y);
	return pr.y - r * cos(sector * 0.5);
}

// Polygon re-centered on its bounding box. sd_polygon centers the shape on
// its circumcenter, but odd side counts are vertically asymmetric (the top
// vertex reaches r while the flat bottom edge stops at the apothem), which
// leaves triangles and pentagons sitting high in their cell compared to
// circles and squares. Even side counts are symmetric and need no offset.
float sd_polygon_centered(float2 p, float r, int n)
{
	int sides = n;
	if (sides < 3) sides = 3;
	float fn = float(sides);
	float yc = 0.0;
	if (frac(fn * 0.5) > 0.25)
		yc = (r * cos(3.14159265 / fn) - r) * 0.5;
	return sd_polygon(float2(p.x, p.y + yc), r, sides);
}

float sd_squircle(float2 p, float r)
{
	float2 ap = abs(p);
	float ax = max(ap.x, 1.0e-5);
	float ay = max(ap.y, 1.0e-5);
	float k = pow(pow(ax, 4.0) + pow(ay, 4.0), 0.25);
	return k - r;
}

float sd_star5(float2 p, float r)
{
	// Exact 5-point star, tip up (y is flipped for screen space). The inner
	// vertices sit at 0.45 of the outer radius.
	float2 k1 = float2(0.809016994, -0.587785252);
	float2 k2 = float2(-k1.x, k1.y);
	float rf = 0.45;
	float2 q = float2(abs(p.x), -p.y);
	q -= 2.0 * max(dot(k1, q), 0.0) * k1;
	q -= 2.0 * max(dot(k2, q), 0.0) * k2;
	q.x = abs(q.x);
	q.y -= r;
	float2 ba = rf * float2(-k1.y, k1.x) - float2(0.0, 1.0);
	float h = clamp(dot(q, ba) / dot(ba, ba), 0.0, r);
	return length(q - ba * h) * sign(q.y * ba.x - q.x * ba.y);
}

float dot2(float2 v)
{
	return dot(v, v);
}

float sd_heart(float2 p, float sz)
{
	// iq's unit heart spans y in [0..1] with the tip at the origin; flip y
	// for screen space and shift so the shape is centered on the cell.
	float s = max(sz, 1.0e-4) * 0.85;
	float2 q = float2(abs(p.x), -p.y) / s + float2(0.0, 0.5);
	float d;
	if (q.y + q.x > 1.0)
		d = sqrt(dot2(q - float2(0.25, 0.75))) - 0.35355339;
	else
		d = sqrt(min(dot2(q - float2(0.0, 1.0)), dot2(q - 0.5 * max(q.x + q.y, 0.0)))) * sign(q.x - q.y);
	return d * s;
}

float hash11(float2 p, float seed)
{
	return frac(sin(dot(p + seed, float2(127.1, 311.7))) * 43758.5453);
}

float2 hash22(float2 p, float seed)
{
	return float2(hash11(p, seed), hash11(p + 17.0, seed + 1.7));
}

float vignette_mask_calc(float2 px)
{
	if (vignette_enabled < 0.5) return 1.0;
	float2 d = px - vignette_center;
	float r = max(vignette_size_px, 1.0);
	float v = 0.0;
	if (vignette_shape == 0) {
		v = length(d) / r;
	} else if (vignette_shape == 1) {
		float2 dir = float2(cos(vignette_direction), sin(vignette_direction));
		v = (dot(d, dir) / r) * 0.5 + 0.5;
	} else if (vignette_shape == 2) {
		float ca = cos(-vignette_direction);
		float sa = sin(-vignette_direction);
		float2 rd = float2(ca * d.x - sa * d.y, sa * d.x + ca * d.y);
		v = max(abs(rd.x), abs(rd.y)) / r;
	} else {
		float ca = cos(-vignette_direction);
		float sa = sin(-vignette_direction);
		float2 rd = float2(ca * d.x - sa * d.y, sa * d.x + ca * d.y);
		float sd = sd_polygon(rd, r, vignette_polygon_sides);
		v = sd / r + 1.0;
	}
	float soft = max(vignette_softness, 0.001);
	float a = 1.0 - smoothstep(1.0 - soft, 1.0, v);
	if (vignette_inverted > 0.5) a = 1.0 - a;
	return saturate(a);
}

float2 cell_local_at(float2 frag_px, int dcol, int drow, out float2 cell_id)
{
	float cs = max(cell_size, 1.0);
	float2 pos = frag_px - anchor;
	float2 axis = lattice_dir;
	float2 perp = float2(-axis.y, axis.x);

	// Decompose the fragment onto the (rotated) lattice axes. The motion
	// offset is already accumulated in lattice coordinates, so the scroll
	// rotates with the lattice around the anchor. Its perpendicular part
	// scrolls whole rows; the along-row part is what alternating lines and
	// speed drift modulate.
	float m_along = dot(pos, axis);
	float m_perp  = dot(pos, perp) - motion_offset.y;

	// Round-to-nearest so cell (0,0) is centered on the anchor.
	float row = floor(m_perp / cs + 0.5) + float(drow);
	float col_shift = motion_offset.x;
	if (alt_lines > 0.5 && frac(row * 0.5) > 0.25)
		col_shift = -col_shift;
	if (drift_speed_amt > 0.0) {
		float s = (hash11(float2(row, 7.0), drift_speed_seed) - 0.5) * 2.0 * drift_speed_amt;
		col_shift *= (1.0 + s);
	}
	float brick_shift = 0.0;
	if (layout_mode > 0.5 && layout_mode < 1.5 && frac(row * 0.5) > 0.25)
		brick_shift = cs * 0.5;
	float m_along_shifted = m_along - col_shift - brick_shift;
	float col = floor(m_along_shifted / cs + 0.5) + float(dcol);

	float la = m_along_shifted - col * cs;
	float lp = m_perp - row * cs;

	if (drift_loc_amt > 0.0) {
		// Animated wander: each cell's shape roams a Lissajous path around
		// the cell center with its own random phase and rate. The slider
		// sets how far it travels (up to drift_loc_amt * cell in each axis).
		float2 ph = hash22(float2(col, row) + 0.5, item_seed) * 6.2831853;
		float2 rate = hash22(float2(col, row) + 17.9, item_seed + 4.7) + 0.5;
		float amp = drift_loc_amt * cs;
		la -= sin(elapsed_time * rate.x + ph.x) * amp;
		lp -= sin(elapsed_time * rate.y + ph.y) * amp;
	}

	cell_id = float2(col, row);
	return float2(la, lp);
}

bool cell_belongs_to_this_item(float2 cell_id)
{
	if (layout_mode < 0.5)
		return true;
	float n = max(step_count, 1.0);
	if (layout_mode > 1.5 && grid_random > 0.5) {
		// Random grid: each cell picks a pseudo-random item. The hash seed
		// is a constant shared by every item's pass, so all passes agree
		// and exactly one item claims each cell.
		float pick = floor(hash11(cell_id + 0.5, 31.7) * n);
		if (pick > n - 1.0)
			pick = n - 1.0;
		return abs(pick - step_index) < 0.5;
	}
	// Step-and-repeat and ordered grid: items cycle by column.
	float raw = cell_id.x;
	float rem = raw - floor(raw / n) * n;
	return abs(rem - step_index) < 0.5;
}

// Number of neighbor cells (in each direction) whose shape can reach the
// current fragment. Without this, large shapes get clipped at cell borders
// and form a visible grid; with it we evaluate every contributing instance.
int tile_reach()
{
	float cs = max(cell_size, 1.0);
	// 0.71 covers the diagonal extent of squares/crosses. The outline stroke
	// is centered on the shape edge, so half of it hangs outside the fill.
	float extent = shape_size * 0.71;
	if (outline_only > 0.5)
		extent += stroke_thickness * shape_size * 0.5;
	extent += drift_loc_amt * cs;
	float r = ceil(extent / cs - 0.5);
	if (r < 0.0) r = 0.0;
	if (r > 8.0) r = 8.0;
	return int(r);
}

float2 rotate2(float2 p, float a)
{
	float c = cos(a);
	float s = sin(a);
	return float2(c * p.x - s * p.y, s * p.x + c * p.y);
}

// Per-cell fade for the Twinkle effect. twinkle_amount selects which cells
// participate; participants fade in and out on their own random phase and
// rate, twinkle_speed cycles per second on average.
float twinkle_alpha_calc(float2 cell_id)
{
	float sel = hash11(cell_id + 3.7, item_seed + 5.13);
	if (sel > twinkle_amount)
		return 1.0;
	float ph = hash11(cell_id + 11.9, item_seed + 7.77) * 6.2831853;
	float rate = 0.75 + 0.5 * hash11(cell_id + 27.3, item_seed + 2.19);
	return sin(elapsed_time * twinkle_speed * 6.2831853 * rate + ph) * 0.5 + 0.5;
}

float shape_sdf(float2 p)
{
	float r = shape_size * 0.5;
	if (shape_kind == 0) return sd_circle(p, r);
	if (shape_kind == 1) return sd_cross(p, r, max(stroke_thickness, 0.05) * shape_size * 0.5);
	if (shape_kind == 2) return sd_box(p, float2(r, r));
	if (shape_kind == 3) return sd_polygon_centered(p, r, polygon_sides);
	if (shape_kind == 4) return sd_squircle(p, r);
	if (shape_kind == 5) return abs(p.y) - r;
	if (shape_kind == 7) return sd_star5(p, r);
	if (shape_kind == 8) return sd_heart(p, shape_size);
	return abs(p.x) - r;
}

float4 PSShape(VertData v_in) : TARGET
{
	float2 frag_px = v_in.uv * canvas_size;
	int reach = tile_reach();
	float stroke_w = max(stroke_thickness, 0.001) * shape_size;
	float alpha;
	if (twinkle_amount > 0.001) {
		// Twinkle needs a per-cell fade, so coverage is computed per
		// instance and combined with max() instead of taking the union
		// SDF. The SDFs are true pixel distances, so a fixed ~0.75 px
		// smoothing gives the same anti-aliasing as the fwidth path.
		alpha = 0.0;
		for (int dr = -reach; dr <= reach; ++dr) {
			for (int dc = -reach; dc <= reach; ++dc) {
				float2 cid;
				float2 p = cell_local_at(frag_px, dc, dr, cid);
				if (!cell_belongs_to_this_item(cid))
					continue;
				p = rotate2(p, shape_rotation);
				float d = shape_sdf(p);
				if (outline_only > 0.5)
					d = abs(d) - stroke_w * 0.5;
				float a = 1.0 - smoothstep(-0.75, 0.75, d);
				alpha = max(alpha, a * twinkle_alpha_calc(cid));
			}
		}
	} else {
		float best_d = 1.0e6;
		for (int dr = -reach; dr <= reach; ++dr) {
			for (int dc = -reach; dc <= reach; ++dc) {
				float2 cid;
				float2 p = cell_local_at(frag_px, dc, dr, cid);
				if (!cell_belongs_to_this_item(cid))
					continue;
				p = rotate2(p, shape_rotation);
				float d = shape_sdf(p);
				best_d = min(best_d, d);
			}
		}
		if (outline_only > 0.5) {
			// Replace the filled SDF with a stroke of width
			// stroke_thickness * shape_size centered on the shape edge
			// (d in [-w/2, +w/2]), so every shape's outline renders with
			// the same visual weight regardless of its SDF interior.
			best_d = abs(best_d) - stroke_w * 0.5;
		}
		// best_d is discontinuous where cell ownership changes
		// (step-and-repeat) or across brick-shifted rows, so an unbounded
		// fwidth() explodes there and smoothstep leaves ~50% alpha seams
		// along cell borders. The SDFs are true pixel distances, so the
		// real edge width never exceeds ~2 px.
		float edge = clamp(fwidth(best_d), 0.5, 2.0);
		alpha = 1.0 - smoothstep(-edge, edge, best_d);
	}
	alpha *= vignette_mask_calc(frag_px);
	return float4(shape_color.rgb, shape_color.a * alpha);
}

float4 PSImage(VertData v_in) : TARGET
{
	float2 frag_px = v_in.uv * canvas_size;
	int reach = tile_reach();
	float half_size = shape_size * 0.5;

	float best_dist2 = 1.0e12;
	float2 best_p = float2(0.0, 0.0);
	float2 best_cid = float2(0.0, 0.0);
	float found = 0.0;
	for (int dr = -reach; dr <= reach; ++dr) {
		for (int dc = -reach; dc <= reach; ++dc) {
			float2 cid;
			float2 p = cell_local_at(frag_px, dc, dr, cid);
			if (!cell_belongs_to_this_item(cid))
				continue;
			p = rotate2(p, shape_rotation);
			if (abs(p.x) <= half_size && abs(p.y) <= half_size) {
				float d2 = dot(p, p);
				if (d2 < best_dist2) {
					best_dist2 = d2;
					best_p = p;
					best_cid = cid;
					found = 1.0;
				}
			}
		}
	}
	if (found < 0.5)
		return float4(0.0, 0.0, 0.0, 0.0);
	float2 uv = (best_p / shape_size) + 0.5;
	float4 tex = cell_texture.Sample(TileSampler, uv);
	tex.a *= shape_color.a * vignette_mask_calc(frag_px);
	if (twinkle_amount > 0.001)
		tex.a *= twinkle_alpha_calc(best_cid);
	tex.rgb *= shape_color.a;
	return tex;
}

technique DrawShape
{
	pass
	{
		vertex_shader = VSDefault(v_in);
		pixel_shader  = PSShape(v_in);
	}
}

technique DrawImage
{
	pass
	{
		vertex_shader = VSDefault(v_in);
		pixel_shader  = PSImage(v_in);
	}
}
