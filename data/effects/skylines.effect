// Constellations - City skyline flat-look effect
// (c) 2026 Eion Dailey - GPLv2+

uniform float4x4 ViewProj;

uniform float2 canvas_size;
uniform float noise_seed;
uniform float drift_px;         // accumulated horizontal slide (Location Drift)
uniform float height_variation; // 0 = uniform roofline, 1 = maximum randomness
uniform float min_height;       // floor of the height range, fraction of canvas
uniform float width_variation;  // 0 = even building widths, 1 = maximum jitter
uniform float min_width;        // floor of the width range, fraction of the base slot
uniform float shade_variation;  // per-building brightness spread, 1 = +/-50%
uniform float window_occupancy; // fraction of windows drawn lit
uniform float4 building_color;
uniform float4 window_on_color;
uniform float4 window_off_color;
uniform float twinkle_active; // 1 only when Window Twinkle is on and speed > 0
uniform float twinkle_phase;  // accumulated twinkle cycles

struct VertData {
	float4 pos : POSITION;
	float2 uv  : TEXCOORD0;
};

VertData VSDefault(VertData v_in)
{
	VertData v_out;
	v_out.pos = mul(float4(v_in.pos.xyz, 1.0), ViewProj);
	v_out.uv  = v_in.uv;
	return v_out;
}

float shash(float n)
{
	return frac(sin(n * 127.1 + noise_seed * 269.5) * 43758.5453);
}

float shash2(float2 p)
{
	return frac(sin(dot(p, float2(127.1, 311.7)) + noise_seed * 269.5) * 43758.5453);
}

float boundary(float i, float slot_w)
{
	// Jittered slot borders give adjacent buildings varied widths while
	// keeping the skyline gap-free. The jitter must stay under half a slot
	// so borders remain ordered and only neighbors can claim a pixel; the
	// Minimum Width floor tightens it further so no building can shrink
	// below min_width of the base slot.
	float amp = min(0.45 * saturate(width_variation), (1.0 - saturate(min_width)) * 0.5);
	return (i + (shash(i) - 0.5) * 2.0 * amp) * slot_w;
}

float4 blend_over(float4 dst, float4 src)
{
	float a = src.a + dst.a * (1.0 - src.a);
	if (a < 1.0e-5)
		return float4(0.0, 0.0, 0.0, 0.0);
	float3 rgb = (src.rgb * src.a + dst.rgb * dst.a * (1.0 - src.a)) / a;
	return float4(rgb, a);
}

float4 PSSkyline(VertData v_in) : TARGET
{
	float2 frag_px = v_in.uv * canvas_size;
	float ch = canvas_size.y;
	float slot_w = 0.085 * ch;
	float x = frag_px.x + drift_px;
	float yb = ch - frag_px.y; // height above the source's bottom edge

	// Resolve which jittered slot this pixel falls in; the jitter never
	// moves a border more than 0.45 slots, so only the neighbors can claim
	// it. Reuse the two nominal borders so most pixels hash three borders
	// instead of four.
	float fi = floor(x / slot_w);
	float b0 = boundary(fi, slot_w);
	float b1 = boundary(fi + 1.0, slot_w);
	float bldg = fi;
	float left = b0;
	float right = b1;
	if (x < b0) {
		bldg = fi - 1.0;
		right = b0;
		left = boundary(fi - 1.0, slot_w);
	} else if (x >= b1) {
		bldg = fi + 1.0;
		left = b1;
		right = boundary(fi + 2.0, slot_w);
	}

	// Roofline: an even 55% of the canvas at zero variation, spreading
	// toward 15%..95% as Building Height Variation approaches 1. The
	// Minimum Height floor lifts the bottom of that range; heights stay
	// uniformly distributed between the floor and the top.
	float hr = frac(sin(bldg * 113.5 + noise_seed * 269.5 + 7.3) * 43758.5453);
	float h_high = 0.55 + 0.4 * saturate(height_variation);
	float h_low = max(0.55 - 0.4 * saturate(height_variation), saturate(min_height));
	float h_px = lerp(h_low, max(h_high, h_low), hr) * ch;

	float body_a = 1.0 - smoothstep(h_px - 0.75, h_px + 0.75, yb);
	if (body_a <= 0.0)
		return float4(0.0, 0.0, 0.0, 0.0);

	// Per-building shading keeps same-height neighbors readable. The
	// Shade Variation slider sets the spread: 0 = uniform color, 1 =
	// +/-50% brightness around the chosen building color.
	float sr = frac(sin(bldg * 91.7 + noise_seed * 269.5 + 3.1) * 43758.5453);
	float shade = 1.0 + (sr - 0.5) * saturate(shade_variation);
	float4 outc = float4(saturate(building_color.rgb * shade), building_color.a);

	// Window grid, scaled with the canvas and inset from every edge so no
	// window is clipped by a roofline, a wall, or the ground.
	float pitch = max(10.0, 0.024 * ch);
	float side_inset = pitch * 0.5;
	float top_inset = pitch * 0.7;
	float bottom_inset = pitch * 0.45;
	float2 wl = float2(x - left - side_inset, (h_px - yb) - top_inset);
	float ncols = floor((right - left - side_inset * 2.0) / pitch);
	float nrows = floor((h_px - top_inset - bottom_inset) / pitch);
	float2 cell = floor(wl / pitch);
	float2 cf = frac(wl / pitch);

	if (wl.x >= 0.0 && wl.y >= 0.0 && cell.x < ncols && cell.y < nrows &&
	    cf.x > 0.20 && cf.x < 0.72 && cf.y > 0.22 && cf.y < 0.78) {
		float2 wid = float2(bldg * 13.7 + cell.x, cell.y - bldg * 5.3);
		float occupied = step(shash2(wid), window_occupancy);
		float lit = occupied;
		if (twinkle_active > 0.5 && occupied > 0.5) {
			// Per-window rate and phase offsets keep fades unsynchronized.
			float rate = 0.6 + 1.4 * shash2(wid + 19.1);
			float ph = shash2(wid + 47.3);
			lit = 0.5 + 0.5 * sin((twinkle_phase * rate + ph) * 6.2831853);
		}
		float4 wc = lerp(window_off_color, window_on_color, lit);
		outc = blend_over(outc, wc);
	}

	outc.a *= body_a;
	return outc;
}

technique Draw
{
	pass
	{
		vertex_shader = VSDefault(v_in);
		pixel_shader  = PSSkyline(v_in);
	}
}
